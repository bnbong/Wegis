{
  "manifest_version": 3,
  "name": "Wegis",
  "version": "2.0.1",
  "description": "Scribbles out dangerous links and QR codes right on the page — like erasing them with a crayon — while blocking phishing, shortened, and malicious download links.",

  "permissions": [
    "activeTab",
    "storage",
    "declarativeNetRequest",
    "downloads",
    "notifications"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://api.bnbong.com/api/v1/wegis-server/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/jsqr.min.js",
        "lib/wegis-core.js",
        "content/link-collector.js",
        "content/content-script.js"
      ],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Wegis",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_page": "options/options.html",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
